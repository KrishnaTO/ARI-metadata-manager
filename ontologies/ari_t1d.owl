<owl:NamedIndividual rdf:about="#T1D_0003">
  <rdf:type rdf:resource="#AutoimmuneDisease"/>
  <hasParentDisease rdf:resource="https://diseases.autoimmuneregistry.org/disease/ARI_0001080"/>
  <hasParentCategory rdf:resource="#Category_Endocrine"/>
  <targetsTissue rdf:resource="#Tissue_BetaCell"/>
  <targetsTissue rdf:resource="#Tissue_Islet"/>
  <hasSymptom rdf:resource="#Sym_Ful_DKA"/>
  <hasSymptom rdf:resource="#Sym_Ful_Flu"/>
  <hasAntibody rdf:resource="#Ab_Ful_GAD65"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fulminant type 1 diabetes</rdfs:label>
  <ARI_ID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ARI:0003</ARI_ID>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fulminant T1D is a rare, abrupt-onset subtype characterized by very rapid beta-cell destruction over days, near-normal HbA1c at presentation despite severe hyperglycemia, and frequent absence of islet autoantibodies. Most cases are reported in East Asia.</rdfs:comment>
  <ARI_Obsolete rdf:datatype="http://www.w3.org/2001/XMLSchema#string">false</ARI_Obsolete>
  <ARI_Version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</ARI_Version>
  <diseaseCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune</diseaseCategory>
  <evidenceQuality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Moderate</evidenceQuality>
  <ageRange rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Any age; often associated with pregnancy</ageRange>
  <prevalencePer100k rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.5</prevalencePer100k>
  <ARI_PrevalenceDesc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rare; predominantly East Asian populations. &lt;1/100k.</ARI_PrevalenceDesc>
  <ARI_DefSource rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Japan Diabetes Society criteria; PMID: 22912766</ARI_DefSource>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fulminant diabetes</ARI_Synonym>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Acute-onset type 1 diabetes</ARI_Synonym>
  <ARI_UMLS rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C2349037</ARI_UMLS>
  <ARI_MONDO rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MONDO:0014523</ARI_MONDO>
  <ARI_ICD10 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">E10</ARI_ICD10>
  <ARI_ChangeLog rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-06-12 | System | Initial subtype entry</ARI_ChangeLog>
</owl:NamedIndividual>

