  <ARI_UMLS rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C0019050</ARI_UMLS>
  <ARI_UMLS rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C0086774</ARI_UMLS>
  <ARI_UMLS rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C0024790</ARI_UMLS>
