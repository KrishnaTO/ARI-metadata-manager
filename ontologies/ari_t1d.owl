  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">We Are Ill - Black Women Living with MS | https://www.weareillmatic.com/</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tripping on Air | https://www.trippingonair.com/</ARI_RefLink>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Multiple Sclerosis, Primary Progressive (PPMS) - Gradual worsening without relapses.</ARI_ClinicalSubtype>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Multiple Sclerosis, Relapsing-Remitting (RRMS) - Most common form with flare-ups.</ARI_ClinicalSubtype>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Balo Concentric Sclerosis, Classic - Rare variant of multiple sclerosis with concentric demyelination.</ARI_ClinicalSubtype>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Multiple Sclerosis, Secondary Progressive (SPMS) - Follows RRMS with worsening symptoms.</ARI_ClinicalSubtype>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Multiple Sclerosis, Progressive-Relapsing (PRMS) - Rare, steady decline with relapses.</ARI_ClinicalSubtype>
