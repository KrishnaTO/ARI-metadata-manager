  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Todd Bello | https://tvsoccerdad.wordpress.com/</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Mayo Clinic | https://www.mayoclinic.org/diseases-conditions/psoriasis/symptoms-causes/syc-20355840</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">National Psoriasis Foundation | http://psoriasis.org/</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Healthline | https://www.healthline.com/health/psoriasis</ARI_RefLink>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Psoriasis, Inverse - Affects folds like armpits.</ARI_ClinicalSubtype>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Psoriasis, Pustular - Severe with pustules.</ARI_ClinicalSubtype>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Psoriasis, Guttate - Small, drop-like lesions.</ARI_ClinicalSubtype>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Psoriasis, Plaque - Most common, red scaly patches.</ARI_ClinicalSubtype>
