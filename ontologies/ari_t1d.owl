  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Healthline | https://www.healthline.com/health/long-covid-symptoms-that-wont-go-away</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Patient Led Research Collaborative | https://patientresearchcovid19.com/</ARI_RefLink>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Long COVID, Cardiopulmonary - Persistent shortness of breath and heart palpitations.</ARI_ClinicalSubtype>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Long COVID, Neurologic - Brain fog, headaches, and cognitive impairment.</ARI_ClinicalSubtype>
