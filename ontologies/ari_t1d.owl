<owl:NamedIndividual rdf:about="https://diseases.autoimmuneregistry.org/disease/ARI_0001086">
  <rdf:type rdf:resource="#AutoimmuneDisease"/>
  <targetsTissue rdf:resource="#Tissue_DigestiveSystem"/>
  <hasSymptom rdf:resource="#Sym_0001086_776"/>
  <hasSymptom rdf:resource="#Sym_0001086_777"/>
