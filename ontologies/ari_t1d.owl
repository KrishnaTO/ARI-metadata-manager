  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vogt-Koyanagi-Harada disease</rdfs:label>
  <ARI_Obsolete rdf:datatype="http://www.w3.org/2001/XMLSchema#string">false</ARI_Obsolete>
  <ARI_ID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ARI:0001210</ARI_ID>
  <ARI_SNOMED rdf:datatype="http://www.w3.org/2001/XMLSchema#string">193497004</ARI_SNOMED>
  <ARI_DOID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">12297</ARI_DOID>
  <ARI_UMLS rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C0042170</ARI_UMLS>
  <ARI_ICD10 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">364.24</ARI_ICD10>
  <ARI_ICD10 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">H20.82</ARI_ICD10>
  <ARI_MESH rdf:datatype="http://www.w3.org/2001/XMLSchema#string">D014607</ARI_MESH>
  <ARI_NCI rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C85218</ARI_NCI>
  <ARI_OMOP rdf:datatype="http://www.w3.org/2001/XMLSchema#string">4108968</ARI_OMOP>
  <ARI_DXCODE rdf:datatype="http://www.w3.org/2001/XMLSchema#string">193497004</ARI_DXCODE>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vogt-Koyanagi-Harada (VKH), is a rare disease that affects multiple systems including the nervous system and skin. The disease results in rapid vision loss as well as loss of hearing and hair. Although the cause of VKH is unknown, researchers believe that it is an immune response to a genetic defect of the Human Leukocyte antigen (HLA). Other researchers believe that there may be a genetic predisposition for VKH and may only be expressed by an environmental trigger.</rdfs:comment>
  <ARI_DefSource rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lavezzo 2016; https://pubmed.ncbi.nlm.nih.gov/27008848/</ARI_DefSource>
  <ARI_Pubmed rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://pubmed.ncbi.nlm.nih.gov/27008848/</ARI_Pubmed>
  <evidenceQuality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Antibody</evidenceQuality>
  <diseaseCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune</diseaseCategory>
  <ARI_Version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2.1</ARI_Version>
  <ageRange rdf:datatype="http://www.w3.org/2001/XMLSchema#string">30-40 years</ageRange>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vogt-Koyanagi-Harada, Acute - Sudden eye inflammation and neurological symptoms.</ARI_ClinicalSubtype>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vogt-Koyanagi-Harada, Chronic - Ongoing skin and eye pigmentation changes.</ARI_ClinicalSubtype>
  <ARI_Author rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune Registry</ARI_Author>
  <ARI_AuthorDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2024-09</ARI_AuthorDate>
  <ARI_SurveyCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">VKH</ARI_SurveyCode>
  <ARI_ChangeLog rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-06-15 10:37 | Importer | Imported from ARI core reports</ARI_ChangeLog>
</owl:NamedIndividual>

