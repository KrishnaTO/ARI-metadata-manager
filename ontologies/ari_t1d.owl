  <hasSymptom rdf:resource="#Sym_0001041_295"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune oophoritis</rdfs:label>
  <ARI_Obsolete rdf:datatype="http://www.w3.org/2001/XMLSchema#string">false</ARI_Obsolete>
  <ARI_ID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ARI:0001041</ARI_ID>
  <ARI_SNOMED rdf:datatype="http://www.w3.org/2001/XMLSchema#string">721198006</ARI_SNOMED>
  <ARI_OMOP rdf:datatype="http://www.w3.org/2001/XMLSchema#string">36717453</ARI_OMOP>
  <ARI_DXCODE rdf:datatype="http://www.w3.org/2001/XMLSchema#string">721198006</ARI_DXCODE>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">In autoimmune oophoritis, the immune system mistakenly attacks the ovaries, causing inflammation, atrophy, and fibrosis. These changes keep the ovaries from working normally, and the result can be primary ovarian insufficiency (POI). Autoimmune oophoritis is associated with lupus, pernicious anemia, myasthenia gravis, autoimmune polyendocrine syndrome type I or type II, and other autoimmune conditions. Special blood tests and imaging are used to diagnose this condition.</rdfs:comment>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Premature ovarian failure due to autoimmune oophoritis</ARI_Synonym>
  <ARI_DefSource rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rudnicka 2018 and Tsigkou 2008; https://pubmed.ncbi.nlm.nih.gov/18211971/</ARI_DefSource>
  <ARI_Pubmed rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://pubmed.ncbi.nlm.nih.gov/18211971/</ARI_Pubmed>
  <evidenceQuality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Immune-mediated</evidenceQuality>
  <diseaseCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune</diseaseCategory>
  <ARI_Version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2</ARI_Version>
  <ageRange rdf:datatype="http://www.w3.org/2001/XMLSchema#string">20-30 years</ageRange>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Healthline | https://www.healthline.com/health/womens-health/oophoritis</ARI_RefLink>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune Oophoritis, Isolated - Targets ovaries, causing infertility.</ARI_ClinicalSubtype>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune Oophoritis, Associated with APS - Occurs with autoimmune polyendocrine syndrome.</ARI_ClinicalSubtype>
  <ARI_Author rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lauren Young | https://www.linkedin.com/in/lauren-young-798443210/</ARI_Author>
  <ARI_AuthorDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2024-05</ARI_AuthorDate>
  <ARI_SurveyCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">AOO</ARI_SurveyCode>
  <ARI_ChangeLog rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-06-15 10:37 | Importer | Imported from ARI core reports</ARI_ChangeLog>
