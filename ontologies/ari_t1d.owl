<owl:NamedIndividual rdf:about="https://diseases.autoimmuneregistry.org/disease/ARI_0001021">
  <rdf:type rdf:resource="#AutoimmuneDisease"/>
  <targetsTissue rdf:resource="#Tissue_Blood"/>
  <hasSymptom rdf:resource="#Sym_0001021_186"/>
  <hasSymptom rdf:resource="#Sym_0001021_187"/>
  <hasSymptom rdf:resource="#Sym_0001021_188"/>
