  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Episcleritis</rdfs:label>
  <ARI_Obsolete rdf:datatype="http://www.w3.org/2001/XMLSchema#string">false</ARI_Obsolete>
  <ARI_ID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ARI:0001088</ARI_ID>
  <ARI_SNOMED rdf:datatype="http://www.w3.org/2001/XMLSchema#string">815008</ARI_SNOMED>
  <ARI_OMOP rdf:datatype="http://www.w3.org/2001/XMLSchema#string">4218083</ARI_OMOP>
  <ARI_DXCODE rdf:datatype="http://www.w3.org/2001/XMLSchema#string">815008</ARI_DXCODE>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Episcleritis is an inflammation of the white tissue, the sclera, that surrounds most of the eye. Though scleritis is a symptom of a number of autoimmune diseases, it is suspected of being an autoimmune disease itself.</rdfs:comment>
  <ARI_DefSource rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Honik 2013; https://pubmed.ncbi.nlm.nih.gov/24145628/</ARI_DefSource>
  <ARI_Pubmed rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://pubmed.ncbi.nlm.nih.gov/24145628/</ARI_Pubmed>
  <evidenceQuality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Antibody</evidenceQuality>
  <diseaseCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune</diseaseCategory>
  <ARI_Version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2</ARI_Version>
  <prevalencePer100k rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">55703.0</prevalencePer100k>
  <ARI_PrevalenceDesc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Female 40149/100k; Male 15553/100k; F:M ratio 2.58143</ARI_PrevalenceDesc>
  <ageRange rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Can occur at any age.</ageRange>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The Ocular Immunology and Uveitis Foundation | https://uveitis.org/</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Cleveland Clinic | https://my.clevelandclinic.org/health/diseases/24974-episcleritis</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Healthline | https://www.healthline.com/health/episcleritis</ARI_RefLink>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Episcleritis, Nodular - Localized, raised inflammatory nodules.</ARI_ClinicalSubtype>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Episcleritis, Simple - Mild inflammation without nodules.</ARI_ClinicalSubtype>
  <ARI_Author rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune Registry</ARI_Author>
