  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Systemic sclerosis with limited cutaneous involvement</rdfs:label>
  <ARI_Obsolete rdf:datatype="http://www.w3.org/2001/XMLSchema#string">false</ARI_Obsolete>
  <ARI_ID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ARI:0001199</ARI_ID>
  <ARI_SNOMED rdf:datatype="http://www.w3.org/2001/XMLSchema#string">31848007</ARI_SNOMED>
  <ARI_SNOMED rdf:datatype="http://www.w3.org/2001/XMLSchema#string">128461001</ARI_SNOMED>
  <ARI_SNOMED rdf:datatype="http://www.w3.org/2001/XMLSchema#string">298285004</ARI_SNOMED>
  <ARI_DOID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">0060218</ARI_DOID>
  <ARI_UMLS rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C0206138</ARI_UMLS>
  <ARI_UMLS rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C1527226</ARI_UMLS>
  <ARI_ICD10 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">M34.1</ARI_ICD10>
  <ARI_MESH rdf:datatype="http://www.w3.org/2001/XMLSchema#string">D017675</ARI_MESH>
  <ARI_NCI rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C70646</ARI_NCI>
  <ARI_OMOP rdf:datatype="http://www.w3.org/2001/XMLSchema#string">4185187, 4135937, 4027230</ARI_OMOP>
  <ARI_DXCODE rdf:datatype="http://www.w3.org/2001/XMLSchema#string">298285004, 31848007, 128461001</ARI_DXCODE>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CREST is a subtype of scleroderma, a connective tissue disease characterized by changes in the skin, blood vessels, skeletal muscles, and internal organs. CREST is the acronym for the clinical features seen in individuals with the disease :                        

C - Calcinosis: calcium deposits in the connective tissues

R - Raynaud's phenomenon: where the hands and feet turn white and cold and then blue, in response to cold or anxiety.

E - Esophageal dysfunction:  where a person has difficulty swallowing 

S - Sclerodactyly: thick and tight skin on the fingers, caused by an excess of collagen deposits within skin layers.

T - Telangiectasia: small red spots on the hands and face that are caused by the swelling of tiny blood vessels.

To be diagnosed with CREST, you must have 3 out of the 5 symptoms.</rdfs:comment>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">dcSSc</ARI_Synonym>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">lcSSc</ARI_Synonym>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CREST syndrome</ARI_Synonym>
  <ARI_DefSource rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Efrimescu 2023; https://pubmed.ncbi.nlm.nih.gov/36686888/</ARI_DefSource>
  <ARI_Pubmed rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://pubmed.ncbi.nlm.nih.gov/36686888/</ARI_Pubmed>
  <evidenceQuality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Antibody Suspected</evidenceQuality>
  <diseaseCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune</diseaseCategory>
  <ARI_Version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2</ARI_Version>
  <ageRange rdf:datatype="http://www.w3.org/2001/XMLSchema#string">30-65 years</ageRange>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Scleroderma Foundation | https://scleroderma.org/</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Professional Patient in Makeup and Mittens | https://professionalpincushioninmittens.wordpress.com/</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Healthline | https://www.healthline.com/health/scleroderma#Systemic-sclerosis</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Cleveland Clinic | https://my.clevelandclinic.org/health/diseases/scleroderma</ARI_RefLink>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Limited Sclerosis, CREST Syndrome - Calcinosis, Raynaud’s, esophageal dysfunction, sclerodactyly, telangiectasia.</ARI_ClinicalSubtype>
  <ARI_Author rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nethra Giri | https://www.linkedin.com/in/nethra-giri-10b56a1b0/</ARI_Author>
