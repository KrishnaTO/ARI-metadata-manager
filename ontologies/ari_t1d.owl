  <hasSymptom rdf:resource="#Sym_0001138_1298"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Myocarditis due to autoimmune disease</rdfs:label>
  <ARI_Obsolete rdf:datatype="http://www.w3.org/2001/XMLSchema#string">false</ARI_Obsolete>
  <ARI_ID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ARI:0001138</ARI_ID>
  <ARI_SNOMED rdf:datatype="http://www.w3.org/2001/XMLSchema#string">871640001</ARI_SNOMED>
  <ARI_SNOMED rdf:datatype="http://www.w3.org/2001/XMLSchema#string">37217002</ARI_SNOMED>
  <ARI_DOID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">0040095</ARI_DOID>
  <ARI_OMOP rdf:datatype="http://www.w3.org/2001/XMLSchema#string">3656114, 321578</ARI_OMOP>
  <ARI_DXCODE rdf:datatype="http://www.w3.org/2001/XMLSchema#string">871640001, 37217002</ARI_DXCODE>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Myocarditis is an inflammation of the heart wall. Myocarditis can affect both the heart's muscle cells and the heart's electrical system, leading to problems with the heart's pumping function and irregular heart rhythms. Myocarditis can also be caused by viral infections or systemic inflammatory conditions such as additional autoimmune disorders. In severe cases of myocarditis, the heart muscle weakens and cannot pump blood effectively to other parts of your body. There are 3 types of myocarditis: acute, chronic, and lymphocytic.</rdfs:comment>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune myocarditis</ARI_Synonym>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune cardiomyopathy</ARI_Synonym>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Coxsackie myocarditis</ARI_Synonym>
  <ARI_DefSource rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lancet 2018; https://www.ncbi.nlm.nih.gov/pmc/articles/PMC6227754/</ARI_DefSource>
  <evidenceQuality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Antibody</evidenceQuality>
  <diseaseCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune</diseaseCategory>
  <ARI_Version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2</ARI_Version>
  <ageRange rdf:datatype="http://www.w3.org/2001/XMLSchema#string">3-35 years</ageRange>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Myocarditis Foundation | http://www.myocarditisfoundation.org/</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Healthline | https://www.healthline.com/health/heart-disease/myocarditis</ARI_RefLink>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Myocarditis, Giant Cell - Severe form with rapid progression.</ARI_ClinicalSubtype>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Myocarditis, Lupus-Associated - Occurs in systemic lupus erythematosus.</ARI_ClinicalSubtype>
  <ARI_Author rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lauren young | https://www.linkedin.com/in/lauren-young-798443210</ARI_Author>
  <ARI_AuthorDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2025-05</ARI_AuthorDate>
  <ARI_SurveyCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MYC</ARI_SurveyCode>
