<owl:NamedIndividual rdf:about="https://diseases.autoimmuneregistry.org/disease/ARI_0001180">
  <rdf:type rdf:resource="#AutoimmuneDisease"/>
  <targetsTissue rdf:resource="#Tissue_VascularSystem"/>
  <hasSymptom rdf:resource="#Sym_0001180_1752"/>
  <hasSymptom rdf:resource="#Sym_0001180_1753"/>
  <hasSymptom rdf:resource="#Sym_0001180_1754"/>
  <hasSymptom rdf:resource="#Sym_0001180_1755"/>
