  <ARI_UMLS rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C0085404</ARI_UMLS>
  <ARI_MESH rdf:datatype="http://www.w3.org/2001/XMLSchema#string">D016878</ARI_MESH>
