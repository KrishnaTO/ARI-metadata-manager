  <hasSymptom rdf:resource="#Sym_0001184_1816"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rheumatoid arthritis</rdfs:label>
  <ARI_Obsolete rdf:datatype="http://www.w3.org/2001/XMLSchema#string">false</ARI_Obsolete>
  <ARI_ID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ARI:0001184</ARI_ID>
  <ARI_SNOMED rdf:datatype="http://www.w3.org/2001/XMLSchema#string">69896004</ARI_SNOMED>
  <ARI_DOID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">7148</ARI_DOID>
  <ARI_UMLS rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C0003873</ARI_UMLS>
  <ARI_ICD10 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">714.0</ARI_ICD10>
  <ARI_ICD10 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">M06.9</ARI_ICD10>
  <ARI_MESH rdf:datatype="http://www.w3.org/2001/XMLSchema#string">D001172</ARI_MESH>
  <ARI_NCI rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C2884</ARI_NCI>
  <ARI_OMOP rdf:datatype="http://www.w3.org/2001/XMLSchema#string">80809</ARI_OMOP>
  <ARI_DXCODE rdf:datatype="http://www.w3.org/2001/XMLSchema#string">69896004</ARI_DXCODE>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rheumatoid arthritis (RA) is an autoimmune disease marked by inflammation and damage to joints, surrounding bone, blood vessels, and connective tissue.   This disorder usually affects both sides of the body (i.e. both ankles or both wrists). It can also damage the lungs, heart, eyes, skin, and various other body systems.    

Joints affected by RA are often painful, stiff, and swollen, especially in the morning, and symptoms typically appear in flares followed by remission.  Research has not determined the cause of RA but associations have been found with certain genes, infections, and hormonal changes.  Risk also increases with inhalation of hazardous particles in certain occupations and chronic smoking.  

There is no cure, though treatments to manage symptoms are available.  Prognosis is dependent on disease severity and timely treatment.  Some patients experience mild symptoms with long remissions, while others experience intense symptoms for extended periods of time with few remissions.  The condition is progressive, and patients often worsen over time.  Patients with severe cases may develop disability due to musculoskeletal damage, and some may experience serious cardiac complications.</rdfs:comment>
  <ARI_DefSource rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Tuncer 2018; https://www.ncbi.nlm.nih.gov/pmc/articles/PMC6117145/</ARI_DefSource>
  <evidenceQuality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Antibody</evidenceQuality>
  <diseaseCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune</diseaseCategory>
  <ARI_Version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2</ARI_Version>
  <prevalencePer100k rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">2154336.0</prevalencePer100k>
  <ARI_PrevalenceDesc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Female 1.70917e+06/100k; Male 445164/100k; F:M ratio 3.83942</ARI_PrevalenceDesc>
  <ageRange rdf:datatype="http://www.w3.org/2001/XMLSchema#string">30-60 years</ageRange>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pollyanna Penguin’s RA Blog | https://pollyannapenguin.wordpress.com/</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rheumatoid Arthritis Foundation | https://www.helpfightra.org/</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Cleveland Clinic | https://my.clevelandclinic.org/health/diseases/4924-rheumatoid-arthritis</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">From This Point Forward | http://www.fromthispointforward.com/</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Arthritis Foundation | https://www.arthritis.org/</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">International Foundation for Autoimmune and Autoinflammatory Arthritis | https://www.aiarthritis.org/</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Healthline | https://www.healthline.com/health/rheumatoid-arthritis</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Mayo Clinic | https://www.mayoclinic.org/diseases-conditions/rheumatoid-arthritis/symptoms-causes/syc-20353648</ARI_RefLink>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">RA, Seronegative - No detectable RF or anti-CCP antibodies.</ARI_ClinicalSubtype>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">RA, Seropositive - Presence of rheumatoid factor (RF) and anti-CCP antibodies.</ARI_ClinicalSubtype>
  <ARI_Author rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Emily Holladay</ARI_Author>
  <ARI_AuthorDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2024-09</ARI_AuthorDate>
  <ARI_SurveyCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">RA</ARI_SurveyCode>
  <ARI_ChangeLog rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-06-15 10:37 | Importer | Imported from ARI core reports</ARI_ChangeLog>
