<owl:NamedIndividual rdf:about="https://diseases.autoimmuneregistry.org/disease/ARI_0001029">
  <rdf:type rdf:resource="#AutoimmuneDisease"/>
  <targetsTissue rdf:resource="#Tissue_NervousSystem"/>
  <hasSymptom rdf:resource="#Sym_0001029_2223"/>
  <hasSymptom rdf:resource="#Sym_0001029_2224"/>
