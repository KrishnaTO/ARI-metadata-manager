<owl:NamedIndividual rdf:about="#Sym_Polyuria">
  <rdf:type rdf:resource="#Symptom"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Polyuria</rdfs:label>
  <likelihood rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Very common (&gt;=90%)</likelihood>
  <symptomDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Excessive urination due to osmotic diuresis from hyperglycemia</symptomDescription>
