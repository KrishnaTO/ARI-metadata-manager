  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Flu-like prodrome</rdfs:label>
  <likelihood rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Common (70%)</likelihood>
  <symptomDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Preceding viral-like illness before abrupt onset</symptomDescription>
  <rdfs:seeAlso rdf:datatype="http://www.w3.org/2001/XMLSchema#string">HP:0033273</rdfs:seeAlso>
  <sourcePMID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://pubmed.ncbi.nlm.nih.gov/17456842/</sourcePMID>
  <ARI_Obsolete rdf:datatype="http://www.w3.org/2001/XMLSchema#string">false</ARI_Obsolete>
</owl:NamedIndividual>

