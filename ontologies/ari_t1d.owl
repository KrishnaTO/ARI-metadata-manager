  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Super rheumatoid disease</ARI_Synonym>
  <ARI_DefSource rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Calgüneri 2006.; https://pubmed.ncbi.nlm.nih.gov/16870099/</ARI_DefSource>
