  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Benign mucous membrane pemphigoid</rdfs:label>
  <ARI_Obsolete rdf:datatype="http://www.w3.org/2001/XMLSchema#string">false</ARI_Obsolete>
  <ARI_ID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ARI:0001054</ARI_ID>
  <ARI_SNOMED rdf:datatype="http://www.w3.org/2001/XMLSchema#string">34250006</ARI_SNOMED>
