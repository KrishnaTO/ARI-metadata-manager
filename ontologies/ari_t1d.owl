  <ARI_SNOMED rdf:datatype="http://www.w3.org/2001/XMLSchema#string">230564004</ARI_SNOMED>
  <ARI_DOID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">5213</ARI_DOID>
  <ARI_UMLS rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C0393819</ARI_UMLS>
