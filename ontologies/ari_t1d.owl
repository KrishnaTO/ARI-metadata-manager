<owl:NamedIndividual rdf:about="https://diseases.autoimmuneregistry.org/disease/ARI_0001146">
  <rdf:type rdf:resource="#AutoimmuneDisease"/>
  <targetsTissue rdf:resource="#Tissue_ThyroidGland"/>
  <hasSymptom rdf:resource="#Sym_0001146_1369"/>
  <hasSymptom rdf:resource="#Sym_0001146_1370"/>
  <hasSymptom rdf:resource="#Sym_0001146_1371"/>
  <hasSymptom rdf:resource="#Sym_0001146_1372"/>
  <hasSymptom rdf:resource="#Sym_0001146_1373"/>
  <hasSymptom rdf:resource="#Sym_0001146_1374"/>
  <hasSymptom rdf:resource="#Sym_0001146_1376"/>
  <hasSymptom rdf:resource="#Sym_0001146_1377"/>
  <hasSymptom rdf:resource="#Sym_0001146_1378"/>
  <hasSymptom rdf:resource="#Sym_0001146_1380"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ophthalmoplegia due to Graves' disease</rdfs:label>
  <ARI_Obsolete rdf:datatype="http://www.w3.org/2001/XMLSchema#string">false</ARI_Obsolete>
  <ARI_ID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ARI:0001146</ARI_ID>
  <ARI_SNOMED rdf:datatype="http://www.w3.org/2001/XMLSchema#string">276177000</ARI_SNOMED>
  <ARI_SNOMED rdf:datatype="http://www.w3.org/2001/XMLSchema#string">104461000119104</ARI_SNOMED>
  <ARI_DOID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">0081120</ARI_DOID>
  <ARI_MESH rdf:datatype="http://www.w3.org/2001/XMLSchema#string">D049970</ARI_MESH>
  <ARI_OMOP rdf:datatype="http://www.w3.org/2001/XMLSchema#string">45757069, 4077943</ARI_OMOP>
  <ARI_DXCODE rdf:datatype="http://www.w3.org/2001/XMLSchema#string">104461000119104, 276177000</ARI_DXCODE>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Graves’ ophthalmopathy (GO) is an autoimmune disorder affecting the eyes that is associated with Graves’ disease.  In Graves’ disease, the immune system targets and damages a specific cell type found in the thyroid.  This cell type is also found in the tissues surrounding the eyes (the orbit), and Graves’ ophthalmopathy results when the immune system attacks these orbital cells in addition to the cells in the thyroid.  

Patients with GO experience swelling in the tissues, muscles, and fat in the eye socket, which leads to an abnormal protrusion of the eye.  Smoking is associated with a greater risk of acquiring GO.  Patients often experience full recovery without intervention, but treatments are available to manage symptoms.</rdfs:comment>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Graves' ophthalmopathy</ARI_Synonym>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Thyroid eye disease</ARI_Synonym>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Graves' orbitopathy</ARI_Synonym>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Graves' eye disease</ARI_Synonym>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Graves ophthalmopathy</ARI_Synonym>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Thyroid-Associated orbitopathy</ARI_Synonym>
  <ARI_DefSource rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Perros 2017; https://www.ncbi.nlm.nih.gov/pmc/articles/PMC5397790/</ARI_DefSource>
  <evidenceQuality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Antibody</evidenceQuality>
  <diseaseCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune</diseaseCategory>
  <ARI_Version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2</ARI_Version>
  <ageRange rdf:datatype="http://www.w3.org/2001/XMLSchema#string">20-50 years</ageRange>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Healthline | https://www.healthline.com/health/graves-disease-eyes</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Graves’ Disease &amp; Thyroid Foundation | https://www.gdatf.org/</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">European group on Graves’ orbitopathy | http://www.eugogo.eu/</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Cleveland Clinic | https://my.clevelandclinic.org/health/diseases/17558-thyroid-eye-disease</ARI_RefLink>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ophthalmoplegia, Mild - Eye movement restriction without vision loss.</ARI_ClinicalSubtype>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ophthalmoplegia, Severe - Progressive vision-threatening involvement.</ARI_ClinicalSubtype>
  <ARI_Author rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Emily Romanello | https://www.linkedin.com/in/emily-romanello-1392432a</ARI_Author>
  <ARI_AuthorDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2024-09</ARI_AuthorDate>
  <ARI_SurveyCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">GED</ARI_SurveyCode>
  <ARI_ChangeLog rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-06-15 10:37 | Importer | Imported from ARI core reports</ARI_ChangeLog>
</owl:NamedIndividual>

