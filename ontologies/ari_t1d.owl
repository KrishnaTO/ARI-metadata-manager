<owl:NamedIndividual rdf:about="https://diseases.autoimmuneregistry.org/disease/ARI_0001187">
  <rdf:type rdf:resource="#AutoimmuneDisease"/>
  <targetsTissue rdf:resource="#Tissue_Musculoskeletal"/>
  <hasSymptom rdf:resource="#Sym_0001187_1863"/>
  <hasSymptom rdf:resource="#Sym_0001187_1864"/>
