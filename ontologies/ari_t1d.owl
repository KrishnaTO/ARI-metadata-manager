<owl:NamedIndividual rdf:about="https://diseases.autoimmuneregistry.org/disease/ARI_0001181">
  <rdf:type rdf:resource="#AutoimmuneDisease"/>
  <targetsTissue rdf:resource="#Tissue_Musculoskeletal"/>
  <hasSymptom rdf:resource="#Sym_0001181_1772"/>
