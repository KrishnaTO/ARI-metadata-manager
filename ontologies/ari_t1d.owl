  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Temporal arteritis</rdfs:label>
  <ARI_Obsolete rdf:datatype="http://www.w3.org/2001/XMLSchema#string">false</ARI_Obsolete>
  <ARI_ID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ARI:0001201</ARI_ID>
