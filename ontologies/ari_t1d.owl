  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune encephalitis occurs when the body's immune system attacks healthy brain cells, causing neurologic and/or psychiatric impairments.</rdfs:comment>
  <ARI_DefSource rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dubey 2018; https://www.ncbi.nlm.nih.gov/pmc/articles/PMC6011827/; 1 million</ARI_DefSource>
  <evidenceQuality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Antibody</evidenceQuality>
  <diseaseCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune</diseaseCategory>
  <ARI_Version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2</ARI_Version>
  <prevalencePer100k rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">4750.0</prevalencePer100k>
  <ARI_PrevalenceDesc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Female 2988/100k; Male 1762/100k; F:M ratio 1.6958</ARI_PrevalenceDesc>
