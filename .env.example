# ===== Server-side only. NEVER expose these to the browser. =====
# GitHub OAuth App credentials (Settings > Developer settings > OAuth Apps)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Repo the app reads ontology data from and writes ontology PRs to
GITHUB_OWNER=KrishnaTO
GITHUB_REPO=ARI
GITHUB_BASE_BRANCH=main
GITHUB_ONTOLOGY_PATH=ontologies/ari_t1d.owl
# Optional server-side token used by deploy/update-ontology.sh for unattended
# ontology refreshes. Leave blank for public repos or if you only fetch after login.
GITHUB_SERVICE_TOKEN=

# Public URL of this app (must match the OAuth App callback URL).
# When behind nginx with a subpath prefix, include it:
#   https://aurint.ca/ari-editor
# For local dev:
#   http://localhost:8001
APP_BASE_URL=https://aurint.ca/ari-editor
OAUTH_CALLBACK_PATH=/auth/github/callback

# Branch of this app repo (ARI-metadata-manager) that deploy/update.sh tracks
APP_REPO_BRANCH=main

# Long random string for signing the session cookie (e.g. `openssl rand -hex 32`)
SESSION_SECRET=replace_with_64_hex_chars

# Optional: comma-separated GitHub logins allowed to use the app (empty = any GitHub user with repo access)
ALLOWED_LOGINS=

PORT=8001
# Days to keep an idle per-user working copy before the sweeper deletes it (0 = never)
USER_DATA_TTL_DAYS=14
