  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Acute febrile mucocutaneous lymph node syndrome</rdfs:label>
  <ARI_Obsolete rdf:datatype="http://www.w3.org/2001/XMLSchema#string">false</ARI_Obsolete>
  <ARI_ID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ARI:0001004</ARI_ID>
  <ARI_SNOMED rdf:datatype="http://www.w3.org/2001/XMLSchema#string">75053002</ARI_SNOMED>
  <ARI_DOID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">13378</ARI_DOID>
  <ARI_UMLS rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C0026691</ARI_UMLS>
  <ARI_ICD10 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">M30.3</ARI_ICD10>
  <ARI_ICD10 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">446.1</ARI_ICD10>
  <ARI_MESH rdf:datatype="http://www.w3.org/2001/XMLSchema#string">D009080</ARI_MESH>
  <ARI_NCI rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C34825</ARI_NCI>
  <ARI_OMOP rdf:datatype="http://www.w3.org/2001/XMLSchema#string">314381</ARI_OMOP>
  <ARI_DXCODE rdf:datatype="http://www.w3.org/2001/XMLSchema#string">75053002</ARI_DXCODE>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Acute febrile mucocutaneous lymph node syndrome, also known as Kawasaki's Disease, is a rare disorder with sudden onset resulting in fever and inflammation of the blood vessels (vasculitis).  This inflammation restricts blood flow and damages vital organs and tissues, leading to heart disease.  Patients are predominantly children.  

The cause of Kawasaki's Disease is uncertain but is believed to be autoimmune.  Patients who do not suffer damage to the coronary arteries (ex. aneurysms) are expected to heal completely.  Patients who do suffer aneurysms are at greater risk of complications and heart failure, but many can be expected to recover within 2 years.  Relapse is uncommon.  Short-term and long-term treatments and procedures that protect the heart and coronary arteries are available.</rdfs:comment>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kawasaki syndrome</ARI_Synonym>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mucocutaneous lymph node syndrome</ARI_Synonym>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lymph node syndrome</ARI_Synonym>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kawasaki's disease</ARI_Synonym>
  <ARI_DefSource rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wu 2012; https://pubmed.ncbi.nlm.nih.gov/22589296/</ARI_DefSource>
  <ARI_Pubmed rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://pubmed.ncbi.nlm.nih.gov/22589296/</ARI_Pubmed>
  <evidenceQuality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Antibody</evidenceQuality>
  <diseaseCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune</diseaseCategory>
  <ARI_Version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2</ARI_Version>
  <prevalencePer100k rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">31107.0</prevalencePer100k>
  <ARI_PrevalenceDesc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Female 11416/100k; Male 19691/100k; F:M ratio 0.579757</ARI_PrevalenceDesc>
  <ageRange rdf:datatype="http://www.w3.org/2001/XMLSchema#string">0-5 years</ageRange>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Healthline | https://www.healthline.com/health/kawasaki-disease</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kawasaki Disease Foundation | https://kdfoundation.org/</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Kawasaki Kids Foundation | https://www.kawasakikidsfoundation.org/</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Cleveland Clinic | https://my.clevelandclinic.org/health/diseases/13457-kawasaki-disease</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vasculitis Foundation | https://www.vasculitisfoundation.org/education/forms/kawasaki-disease/</ARI_RefLink>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Classic Kawasaki Disease - Typical symptoms with fever, rash, and lymphadenopathy.</ARI_ClinicalSubtype>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Incomplete (Atypical) Kawasaki Disease - Lacks some classic criteria, making diagnosis challenging.</ARI_ClinicalSubtype>
  <ARI_Author rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Emily Romanello | https://www.linkedin.com/in/emily-romanello-1392432a</ARI_Author>
  <ARI_AuthorDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2024-09</ARI_AuthorDate>
  <ARI_SurveyCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">KD</ARI_SurveyCode>
