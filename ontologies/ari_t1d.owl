  <hasSymptom rdf:resource="#Sym_0001063_517"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Chronic inflammatory demyelinating polyradiculoneuropathy</rdfs:label>
  <ARI_Obsolete rdf:datatype="http://www.w3.org/2001/XMLSchema#string">false</ARI_Obsolete>
