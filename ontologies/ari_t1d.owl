  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Healthline | https://www.healthline.com/health/morphea</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Children with Scleroderma and Morphea Support Group | https://www.facebook.com/groups/211100285589018/</ARI_RefLink>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Morphea, Plaque-Type - Isolated patches of thickened skin.</ARI_ClinicalSubtype>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Morphea, Generalized - Widespread skin hardening.</ARI_ClinicalSubtype>
