  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pityriasis lichenoides et varioliformis acuta (PLEVA) is the acute form of an inflammatory skin condition called pityriasis lichenoides. People with PLEVA may develop a few to more than one hundred scaling papules which may become filled with blood and/or pus or erode into crusted red-brown spots. Papules may itch or burn, and some people may experience fever or joint pain. Although PLEVA may occur at any age (including infancy), it most commonly affects children and young adults.</rdfs:comment>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mucha-Habermann disease</ARI_Synonym>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PLEVA</ARI_Synonym>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Acuta guttale parapsoriasis</ARI_Synonym>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pityriasis lichenoides et varioliformis acuta</ARI_Synonym>
  <ARI_DefSource rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Medscape 2020; https://www.medscape.com/answers/1099078-102824/what-is-the-prevalence-of-pityriasis-lichenoides-in-the-us</ARI_DefSource>
  <evidenceQuality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Unconfirmed</evidenceQuality>
  <diseaseCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Unconfirmed</diseaseCategory>
  <ARI_Version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2</ARI_Version>
  <ageRange rdf:datatype="http://www.w3.org/2001/XMLSchema#string">0-30 years</ageRange>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">My journey in fighting PLEVA | http://fightpleva.blogspot.com/</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Battle Against Pleva Or Mucha-Habberman's Disease | https://www.facebook.com/groups/battlepleva/</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pleva (Pityriasis lichenoides) | https://www.facebook.com/groups/398134663689549/</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PLEVA | https://www.facebook.com/PLEVA-481828915208633/</ARI_RefLink>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pityriasis Lichenoides Chronica (PLC) - Milder, chronic form with scaly, reddish-brown papules.</ARI_ClinicalSubtype>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Pityriasis Lichenoides et Varioliformis Acuta (PLEVA) - Sudden onset of red papules that evolve into vesicles or ulcers.</ARI_ClinicalSubtype>
  <ARI_Author rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cate Scarrow</ARI_Author>
  <ARI_AuthorDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2024-09</ARI_AuthorDate>
  <ARI_SurveyCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ALP</ARI_SurveyCode>
  <ARI_ChangeLog rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-06-15 10:37 | Importer | Imported from ARI core reports</ARI_ChangeLog>
</owl:NamedIndividual>

