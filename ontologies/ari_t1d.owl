<owl:NamedIndividual rdf:about="https://diseases.autoimmuneregistry.org/disease/ARI_0001050">
  <rdf:type rdf:resource="#AutoimmuneDisease"/>
  <targetsTissue rdf:resource="#Tissue_Skin"/>
  <hasSymptom rdf:resource="#Sym_0001050_385"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune urticaria and/or angioedema</rdfs:label>
  <ARI_Obsolete rdf:datatype="http://www.w3.org/2001/XMLSchema#string">false</ARI_Obsolete>
  <ARI_ID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ARI:0001050</ARI_ID>
  <ARI_SNOMED rdf:datatype="http://www.w3.org/2001/XMLSchema#string">402402005</ARI_SNOMED>
  <ARI_OMOP rdf:datatype="http://www.w3.org/2001/XMLSchema#string">4221673</ARI_OMOP>
  <ARI_DXCODE rdf:datatype="http://www.w3.org/2001/XMLSchema#string">402402005</ARI_DXCODE>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Both &lt;a href="/Disease_Profile/autoimmune-urticaria.aspx"&gt;autoimmune urticaria&lt;/a&gt; and &lt;a href="/Disease_Profile/autoimmune-angioedema.aspx"&gt;autoimmune angioedema&lt;/a&gt; are skin conditions associated with other autoimmune diseases. Urticaria is marked by raised, itchy, and red or pale areas, known as hives. Angioedema is swelling in skin and mucous membranes, including the mouth and throat, and is a more serious condition than urticaria. 

While they are also diseases on their own, patients will receive a diagnosis of a chronic version of the disease because the ICD coding system used in the medical record does not have codes for either disease. The SNOMED coding system (used in Europe) has a code for each condition, and for this combined term.</rdfs:comment>
  <ARI_DefSource rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Murdaca 2023; https://www.ncbi.nlm.nih.gov/pmc/articles/PMC9953398/</ARI_DefSource>
  <evidenceQuality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Antibody</evidenceQuality>
  <diseaseCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune</diseaseCategory>
  <ARI_Version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2</ARI_Version>
  <ageRange rdf:datatype="http://www.w3.org/2001/XMLSchema#string">20-40 years</ageRange>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Healthline | https://www.healthline.com/health/skin/autoimmune-hives</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Cleveland Clinic | https://my.clevelandclinic.org/health/diseases/22900-chronic-hives-chronic-idiopathic-urticaria</ARI_RefLink>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune Urticaria/Angioedema, Complement-Mediated - Linked to complement system dysregulation.</ARI_ClinicalSubtype>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune Urticaria/Angioedema, Mast Cell-Mediated - Caused by abnormal immune response.</ARI_ClinicalSubtype>
  <ARI_SurveyCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NULL</ARI_SurveyCode>
  <ARI_ChangeLog rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-06-15 10:37 | Importer | Imported from ARI core reports</ARI_ChangeLog>
</owl:NamedIndividual>

