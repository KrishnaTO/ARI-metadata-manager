  <hasSymptom rdf:resource="#Sym_0001200_2222"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Takayasu's arteritis</rdfs:label>
  <ARI_Obsolete rdf:datatype="http://www.w3.org/2001/XMLSchema#string">false</ARI_Obsolete>
  <ARI_ID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ARI:0001200</ARI_ID>
  <ARI_SNOMED rdf:datatype="http://www.w3.org/2001/XMLSchema#string">359789008</ARI_SNOMED>
  <ARI_DOID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2508</ARI_DOID>
  <ARI_UMLS rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C0003490</ARI_UMLS>
  <ARI_UMLS rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C0039263</ARI_UMLS>
  <ARI_ICD10 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">446.7</ARI_ICD10>
  <ARI_ICD10 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">M31.4</ARI_ICD10>
  <ARI_MESH rdf:datatype="http://www.w3.org/2001/XMLSchema#string">D001015</ARI_MESH>
  <ARI_MESH rdf:datatype="http://www.w3.org/2001/XMLSchema#string">D013625</ARI_MESH>
  <ARI_NCI rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C34391</ARI_NCI>
  <ARI_NCI rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C35062</ARI_NCI>
  <ARI_OMOP rdf:datatype="http://www.w3.org/2001/XMLSchema#string">440740</ARI_OMOP>
  <ARI_DXCODE rdf:datatype="http://www.w3.org/2001/XMLSchema#string">359789008</ARI_DXCODE>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Takayasu’s arteritis (TA) is a rare disease that affects large blood vessels, especially the aorta and its major branches. It is sometimes called "pulseless disease" because it can weaken or block pulses in the arms and legs. The condition mainly affects young women, particularly those from Asian and South American countries. Although it is most common in women under 40, TA can also occur in men and older individuals. 

In Takayasu’s arteritis, inflammation causes the walls of affected arteries to become thickened and scarred, which can reduce blood flow to important organs and limbs. The disease is marked by patches of severe inflammation in the artery walls, often alternating with areas of normal tissue. Over time, the arteries can become narrowed (stenosis) or, in some cases, develop bulges (aneurysms). The aortic wall is often involved, with inflammatory cells such as lymphocytes and plasma cells attacking the outermost layers of the artery and sometimes extending into the surrounding tissues. 
 
Early symptoms may include fever, night sweats, fatigue, joint pain, and chest discomfort. As the disease progresses, inflammation and damage to major arteries can lead to headaches, dizziness, vision problems, and even fainting due to reduced blood flow to the brain. Narrowing of the arteries supplying the arms and upper body can cause pain and weakness, while involvement of the coronary arteries can result in chest pain and an increased risk of heart disease, including aortic regurgitation, a serious condition that allows blood to flow backward into the heart and can lead to heart failure.</rdfs:comment>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Takayasu's disease</ARI_Synonym>
  <ARI_DefSource rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Watts 2009; https://pubmed.ncbi.nlm.nih.gov/19542212/</ARI_DefSource>
  <ARI_Pubmed rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://pubmed.ncbi.nlm.nih.gov/19542212/</ARI_Pubmed>
  <evidenceQuality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">TCELL</evidenceQuality>
  <diseaseCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune</diseaseCategory>
  <ARI_Version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2</ARI_Version>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vasculitis Foundation | https://www.vasculitisfoundation.org/</ARI_RefLink>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Type V - Combined features of Type IIb and Type IV (i.e., entire aorta and branches)</ARI_ClinicalSubtype>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Type IIa - Ascending aorta, aortic arch, and its branches</ARI_ClinicalSubtype>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Type III - Thoracic descending aorta, abdominal aorta, and/or renal arteries</ARI_ClinicalSubtype>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Type IV - Abdominal aorta and/or renal arteries</ARI_ClinicalSubtype>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Type I - Branches of the aortic arch (e.g., carotid, subclavian)</ARI_ClinicalSubtype>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Type IIb - Type IIa plus thoracic descending aorta</ARI_ClinicalSubtype>
  <ARI_SurveyCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">TAK</ARI_SurveyCode>
  <ARI_ChangeLog rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-06-15 10:37 | Importer | Imported from ARI core reports</ARI_ChangeLog>
</owl:NamedIndividual>

