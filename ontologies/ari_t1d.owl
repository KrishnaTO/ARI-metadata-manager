  <hasSymptom rdf:resource="#Sym_0001076_688"/>
  <hasSymptom rdf:resource="#Sym_0001076_689"/>
  <hasSymptom rdf:resource="#Sym_0001076_690"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cutaneous lupus erythematosus</rdfs:label>
  <ARI_Obsolete rdf:datatype="http://www.w3.org/2001/XMLSchema#string">false</ARI_Obsolete>
  <ARI_ID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ARI:0001076</ARI_ID>
  <ARI_SNOMED rdf:datatype="http://www.w3.org/2001/XMLSchema#string">239891002</ARI_SNOMED>
  <ARI_SNOMED rdf:datatype="http://www.w3.org/2001/XMLSchema#string">200941006</ARI_SNOMED>
  <ARI_SNOMED rdf:datatype="http://www.w3.org/2001/XMLSchema#string">7119001</ARI_SNOMED>
  <ARI_SNOMED rdf:datatype="http://www.w3.org/2001/XMLSchema#string">200938002</ARI_SNOMED>
  <ARI_SNOMED rdf:datatype="http://www.w3.org/2001/XMLSchema#string">403495008</ARI_SNOMED>
  <ARI_SNOMED rdf:datatype="http://www.w3.org/2001/XMLSchema#string">238927000</ARI_SNOMED>
  <ARI_DOID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">0050169</ARI_DOID>
  <ARI_OMOP rdf:datatype="http://www.w3.org/2001/XMLSchema#string">4081248, 4324123, 4066824, 4295301, 4066481, 4343923</ARI_OMOP>
  <ARI_DXCODE rdf:datatype="http://www.w3.org/2001/XMLSchema#string">238927000, 7119001, 200938002, 403495008, 200941006, 239891002</ARI_DXCODE>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Discoid lupus erythematosus, also referred to as DLE, is a chronic but localized skin condition where sores (lesions) form on the scalp, face, elbow, or fingertips. In DLE, the autoimmune system attacks connective tissue. The lesions are red, inflamed patches with a scaling and crusting appearance. If present in areas with a significant amount of hair, the lesions can cause scarring and hair loss in that area. Because the symptoms are similar to other skin diseases and other types of lupus, a skin biopsy must be performed to confirm a diagnosis.  The primary difference between discoid lupus erythematosus (DLE) and systemic lupus erythematosus (SLE) is that DLE mainly affects the skin, while SLE also affects the organs, such as the heart, blood vessels, nervous system, and kidneys. Patients can have both DLE and SLE.</rdfs:comment>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Discoid lupus erythematosus of oral mucosa</ARI_Synonym>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Discoid lupus</ARI_Synonym>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Discoid lupus erythematosus</ARI_Synonym>
  <ARI_DefSource rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Gauzere 2019; https://pubmed.ncbi.nlm.nih.gov/30041816/</ARI_DefSource>
  <ARI_Pubmed rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://pubmed.ncbi.nlm.nih.gov/30041816/</ARI_Pubmed>
  <evidenceQuality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Antibody</evidenceQuality>
  <diseaseCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune</diseaseCategory>
  <ARI_Version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2</ARI_Version>
  <prevalencePer100k rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">82903.0</prevalencePer100k>
  <ARI_PrevalenceDesc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Female 72482/100k; Male 10420/100k; F:M ratio 6.95605</ARI_PrevalenceDesc>
  <ageRange rdf:datatype="http://www.w3.org/2001/XMLSchema#string">40-50 years</ageRange>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lupus Research Alliance | https://www.lupusresearch.org/stay-informed/community/</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Healthline | https://www.healthline.com/health/discoid-lupus</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lupus Connect (forum) | https://www.inspire.com/groups/lupusconnect/</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Cleveland Clinic | https://my.clevelandclinic.org/health/diseases/21601-cutaneous-lupus-skin-lupus</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lupus Foundation of America | https://www.lupus.org/</ARI_RefLink>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cutaneous Lupus, Subacute - Non-scarring, photosensitive lesions.</ARI_ClinicalSubtype>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cutaneous Lupus, Discoid - Causes scarring skin lesions.</ARI_ClinicalSubtype>
  <ARI_Author rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Brooke Juday</ARI_Author>
  <ARI_AuthorDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2024-09</ARI_AuthorDate>
  <ARI_SurveyCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CLE</ARI_SurveyCode>
  <ARI_ChangeLog rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-06-15 10:37 | Importer | Imported from ARI core reports</ARI_ChangeLog>
</owl:NamedIndividual>

