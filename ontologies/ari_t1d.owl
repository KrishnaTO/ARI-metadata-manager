  <ARI_OMOP rdf:datatype="http://www.w3.org/2001/XMLSchema#string">81931, 40319772</ARI_OMOP>
  <ARI_DXCODE rdf:datatype="http://www.w3.org/2001/XMLSchema#string">156370009, 33339001</ARI_DXCODE>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Psoriatic arthritis is an autoimmune disease marked by the combination of psoriasis and one or more forms of rheumatoid-like arthritis, including anklosing spondylitis, rheumatoid arthritis, and juvenile rheumatoid arthritis.</rdfs:comment>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PsA</ARI_Synonym>
