  <ARI_UMLS rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C0030804</ARI_UMLS>
  <ARI_UMLS rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C0157721</ARI_UMLS>
