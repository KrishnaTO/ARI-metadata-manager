<owl:NamedIndividual rdf:about="https://diseases.autoimmuneregistry.org/disease/ARI_0001185">
  <rdf:type rdf:resource="#AutoimmuneDisease"/>
  <targetsTissue rdf:resource="#Tissue_VascularSystem"/>
  <hasSymptom rdf:resource="#Sym_0001185_1818"/>
  <hasSymptom rdf:resource="#Sym_0001185_1819"/>
  <hasSymptom rdf:resource="#Sym_0001185_1820"/>
  <hasSymptom rdf:resource="#Sym_0001185_1821"/>
