<owl:NamedIndividual rdf:about="https://diseases.autoimmuneregistry.org/disease/ARI_0001032">
  <rdf:type rdf:resource="#AutoimmuneDisease"/>
  <targetsTissue rdf:resource="#Tissue_Blood"/>
  <hasSymptom rdf:resource="#Sym_0001032_241"/>
  <hasSymptom rdf:resource="#Sym_0001032_243"/>
  <hasSymptom rdf:resource="#Sym_0001032_244"/>
  <hasSymptom rdf:resource="#Sym_0001032_245"/>
  <hasSymptom rdf:resource="#Sym_0001032_246"/>
  <hasSymptom rdf:resource="#Sym_0001032_247"/>
  <hasSymptom rdf:resource="#Sym_0001032_248"/>
  <hasSymptom rdf:resource="#Sym_0001032_249"/>
  <hasSymptom rdf:resource="#Sym_0001032_250"/>
  <hasSymptom rdf:resource="#Sym_0001032_251"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune hemolytic anemia</rdfs:label>
  <ARI_Obsolete rdf:datatype="http://www.w3.org/2001/XMLSchema#string">false</ARI_Obsolete>
  <ARI_ID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ARI:0001032</ARI_ID>
  <ARI_SNOMED rdf:datatype="http://www.w3.org/2001/XMLSchema#string">413603009</ARI_SNOMED>
  <ARI_SNOMED rdf:datatype="http://www.w3.org/2001/XMLSchema#string">718716008</ARI_SNOMED>
  <ARI_DOID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">718</ARI_DOID>
  <ARI_UMLS rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C0002880</ARI_UMLS>
  <ARI_ICD10 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">283.0</ARI_ICD10>
  <ARI_MESH rdf:datatype="http://www.w3.org/2001/XMLSchema#string">D000744</ARI_MESH>
  <ARI_NCI rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C34378</ARI_NCI>
  <ARI_OMOP rdf:datatype="http://www.w3.org/2001/XMLSchema#string">441269, 36713763</ARI_OMOP>
  <ARI_DXCODE rdf:datatype="http://www.w3.org/2001/XMLSchema#string">413603009, 718716008</ARI_DXCODE>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">In autoimmune hemolytic anemia, red blood cells are destroyed by antibodies. In some cases, the antibodies are active only when the person is warm, in which case it is called &lt;a href="/Disease_Profile/warm-autoimmune-hemolytic-anemia.aspx"&gt;warm autoimmune hemolytic anemia&lt;/a&gt;. In other cases, the antibodies are active when the person is cold, and it is called &lt;a href="/Disease_Profile/cold-agglutinin-disease.aspx"&gt;cold agglutinin disease&lt;/a&gt;, and in others, the antibodies can be active regardless of the person's body temperature. There is also a form of hemolytic anemia called &lt;a href="/Disease_Profile/paroxysmal-nocturnal-hemoglobinuria.aspx"&gt;paroxysmal nocturnal hemoglobinuria&lt;/a&gt;, in which a genetic mutation causes antibodies to cause the same kind of destruction of red blood cells.</rdfs:comment>
  <ARI_DefSource rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bozzi 2023; https://ashpublications.org/blood/article/142/Supplement%201/5202/501456/Prevalence-and-Incidence-of-Primary-Autoimmune</ARI_DefSource>
  <evidenceQuality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Antibody</evidenceQuality>
  <diseaseCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune</diseaseCategory>
  <ARI_Version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2</ARI_Version>
  <ageRange rdf:datatype="http://www.w3.org/2001/XMLSchema#string">50-75 years</ageRange>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Cleveland Clinic | https://my.clevelandclinic.org/health/diseases/22349-autoimmune-hemolytic-anemia</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Healthline | https://www.healthline.com/health/idiopathic-autoimmune-hemolytic-anemia</ARI_RefLink>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune Hemolytic Anemia, Warm - Caused by IgG antibodies active at body temperature.</ARI_ClinicalSubtype>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune Hemolytic Anemia, Cold (Cold Agglutinin Disease) - Mediated by IgM antibodies at cold temperatures.</ARI_ClinicalSubtype>
  <ARI_Author rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Darrison Haftarczyk | www.linkedin.com/in/darrison-haftarczyk-579418190</ARI_Author>
  <ARI_AuthorDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2023-01</ARI_AuthorDate>
  <ARI_SurveyCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">AHA</ARI_SurveyCode>
  <ARI_ChangeLog rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-06-15 10:37 | Importer | Imported from ARI core reports</ARI_ChangeLog>
</owl:NamedIndividual>

