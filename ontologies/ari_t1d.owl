  <ARI_UMLS rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C0017531</ARI_UMLS>
  <ARI_UMLS rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C2931179</ARI_UMLS>
  <ARI_ICD10 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">D47.Z2</ARI_ICD10>
  <ARI_MESH rdf:datatype="http://www.w3.org/2001/XMLSchema#string">D005871</ARI_MESH>
  <ARI_MESH rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C536362</ARI_MESH>
