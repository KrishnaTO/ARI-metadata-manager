  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A disorder where the tissue that normally lines the uterus grows outside of the uterus. The tissue can grow on the ovaries, fallopian tubes, outer wall of the uterus, intestines, or other organs in the belly.</rdfs:comment>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Adenomysis uteri</ARI_Synonym>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Endometriosis Uterina</ARI_Synonym>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Adenomyometritis</ARI_Synonym>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Adenomyosis</ARI_Synonym>
  <ARI_DefSource rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Eisenberg 2017; https://pubmed.ncbi.nlm.nih.gov/28444957/</ARI_DefSource>
