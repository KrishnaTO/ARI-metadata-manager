  <hasSymptom rdf:resource="#Sym_0001023_207"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune angioedema</rdfs:label>
  <ARI_Obsolete rdf:datatype="http://www.w3.org/2001/XMLSchema#string">false</ARI_Obsolete>
  <ARI_ID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ARI:0001023</ARI_ID>
  <ARI_SNOMED rdf:datatype="http://www.w3.org/2001/XMLSchema#string">402401003</ARI_SNOMED>
  <ARI_OMOP rdf:datatype="http://www.w3.org/2001/XMLSchema#string">4224624</ARI_OMOP>
  <ARI_DXCODE rdf:datatype="http://www.w3.org/2001/XMLSchema#string">402401003</ARI_DXCODE>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Angioedema is swelling of the tissue just beneath the skin, including the face, lips, tongue, limbs, or genitals. People with Autoimmune Angioedema can have edema of the lining of the digestive tract, which can cause abdominal pain and nausea, as well as edema of the upper airway, which can be life-threatening.</rdfs:comment>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Acquired angiodema</ARI_Synonym>
  <ARI_DefSource rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Swanson 2020; https://www.ncbi.nlm.nih.gov/books/NBK430889/</ARI_DefSource>
  <evidenceQuality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Antibody Suspected</evidenceQuality>
  <diseaseCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune</diseaseCategory>
  <ARI_Version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2</ARI_Version>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Healthline | https://www.healthline.com/health/angioedema</ARI_RefLink>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune Angioedema, C1-Inhibitor Deficiency - Caused by autoantibodies affecting complement regulation.</ARI_ClinicalSubtype>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune Angioedema, Idiopathic - No clear cause but linked to immune dysfunction.</ARI_ClinicalSubtype>
  <ARI_Author rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune Registry</ARI_Author>
  <ARI_AuthorDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2024-09</ARI_AuthorDate>
  <ARI_SurveyCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ANG</ARI_SurveyCode>
  <ARI_ChangeLog rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-06-15 10:37 | Importer | Imported from ARI core reports</ARI_ChangeLog>
</owl:NamedIndividual>

