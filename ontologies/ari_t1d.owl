  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Angiofollicular lymph node hyperplasia</rdfs:label>
  <ARI_Obsolete rdf:datatype="http://www.w3.org/2001/XMLSchema#string">false</ARI_Obsolete>
