<owl:NamedIndividual rdf:about="https://diseases.autoimmuneregistry.org/disease/ARI_0001003">
  <rdf:type rdf:resource="#AutoimmuneDisease"/>
  <targetsTissue rdf:resource="#Tissue_NervousSystem"/>
  <hasSymptom rdf:resource="#Sym_0001003_27"/>
  <hasSymptom rdf:resource="#Sym_0001003_28"/>
  <hasSymptom rdf:resource="#Sym_0001003_29"/>
  <hasSymptom rdf:resource="#Sym_0001003_30"/>
  <hasSymptom rdf:resource="#Sym_0001003_31"/>
  <hasSymptom rdf:resource="#Sym_0001003_32"/>
