  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Antiphospholipid Syndrome, Secondary - Associated with autoimmune diseases like lupus.</ARI_ClinicalSubtype>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Antiphospholipid Syndrome, Primary - Occurs without an underlying condition.</ARI_ClinicalSubtype>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Antiphospholipid Syndrome, Catastrophic - Severe, life-threatening form with multiple organ involvement.</ARI_ClinicalSubtype>
