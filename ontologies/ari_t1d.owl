  <rdf:type rdf:resource="#EtiologyOrigin"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Molecular mimicry</rdfs:label>
  <etiologyOriginType rdf:datatype="http://www.w3.org/2001/XMLSchema#string">External</etiologyOriginType>
  <etiologyDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Coxsackie P2-C / GAD65 homology drives cross-reactive T-cells</etiologyDescription>
  <etiologyExcerpt rdf:datatype="http://www.w3.org/2001/XMLSchema#string">"Sequence homology between Coxsackievirus P2-C and GAD65 may elicit cross-reactive responses."</etiologyExcerpt>
  <sourcePMID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://pubmed.ncbi.nlm.nih.gov/24814487/</sourcePMID>
  <ARI_Obsolete rdf:datatype="http://www.w3.org/2001/XMLSchema#string">false</ARI_Obsolete>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Et_ERStress">
