<owl:NamedIndividual rdf:about="https://diseases.autoimmuneregistry.org/disease/ARI_0001140">
  <rdf:type rdf:resource="#AutoimmuneDisease"/>
  <targetsTissue rdf:resource="#Tissue_VascularSystem"/>
  <hasSymptom rdf:resource="#Sym_0001140_1310"/>
  <hasSymptom rdf:resource="#Sym_0001140_1311"/>
