  <hasSymptom rdf:resource="#Sym_0001162_1582"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Polymyositis</rdfs:label>
  <ARI_Obsolete rdf:datatype="http://www.w3.org/2001/XMLSchema#string">false</ARI_Obsolete>
  <ARI_ID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ARI:0001162</ARI_ID>
  <ARI_SNOMED rdf:datatype="http://www.w3.org/2001/XMLSchema#string">31384009</ARI_SNOMED>
  <ARI_DOID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">0080745</ARI_DOID>
  <ARI_MESH rdf:datatype="http://www.w3.org/2001/XMLSchema#string">D017285</ARI_MESH>
  <ARI_OMOP rdf:datatype="http://www.w3.org/2001/XMLSchema#string">80800</ARI_OMOP>
  <ARI_DXCODE rdf:datatype="http://www.w3.org/2001/XMLSchema#string">31384009</ARI_DXCODE>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Polymyositis is inflammation of muscle tissue, causing chronic muscle weakness in both sides of the body. This results in mobility issues, such as difficulty climbing stairs, rising from a seated position, lifting objects, etc. Polymyositis mostly affects adults ages 30 to 50s, and women are usually more often affected compared to men. This disease develops gradually, affecting both sides of the muscles closest to the trunk, such as the hips, neck, upper arms, and thighs. The risk of polymyositis increases if already diagnosed with another autoimmune disease, for example, lupus, rheumatoid arthritis, scleroderma, or Sjogren’s syndrome.</rdfs:comment>
  <ARI_DefSource rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Cheeti 2020; https://www.ncbi.nlm.nih.gov/books/NBK532860/</ARI_DefSource>
  <evidenceQuality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Antibody</evidenceQuality>
  <diseaseCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune</diseaseCategory>
  <ARI_Version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2</ARI_Version>
  <prevalencePer100k rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">65816.0</prevalencePer100k>
  <ARI_PrevalenceDesc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Female 44976/100k; Male 20840/100k; F:M ratio 2.15816</ARI_PrevalenceDesc>
  <ageRange rdf:datatype="http://www.w3.org/2001/XMLSchema#string">31-60 years</ageRange>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Myositis Support and Understanding Association | https://understandingmyositis.org/</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Cleveland Clinic | https://my.clevelandclinic.org/health/diseases/12053-polymyositis</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Mayo Clinic | https://www.mayoclinic.org/diseases-conditions/polymyositis/symptoms-causes/syc-20353208</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The Myositis Association | https://www.myositis.org/</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Healthline | https://www.healthline.com/health/polymyositis</ARI_RefLink>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Polymyositis, Classic - Symmetric muscle weakness without rash.</ARI_ClinicalSubtype>
  <ARI_Author rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Erica Matute-Arcos</ARI_Author>
  <ARI_AuthorDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2025-02</ARI_AuthorDate>
