  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">POEMS syndrome</rdfs:label>
  <ARI_Obsolete rdf:datatype="http://www.w3.org/2001/XMLSchema#string">false</ARI_Obsolete>
  <ARI_ID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ARI:0001155</ARI_ID>
  <ARI_SNOMED rdf:datatype="http://www.w3.org/2001/XMLSchema#string">79268002</ARI_SNOMED>
