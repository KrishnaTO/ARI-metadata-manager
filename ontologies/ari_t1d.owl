<owl:NamedIndividual rdf:about="#Path_1_Genetic">
  <rdf:type rdf:resource="#PathwayStep"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Genetic susceptibility</rdfs:label>
  <stepOrder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</stepOrder>
  <stepCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Genetic</stepCategory>
  <stepDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">HLA-DR3/DR4-DQ, INS VNTR, PTPN22, CTLA4 establish a permissive genetic background.</stepDescription>
  <sourcePMID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://pubmed.ncbi.nlm.nih.gov/25471517/</sourcePMID>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Path_2_Trigger">
  <rdf:type rdf:resource="#PathwayStep"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Environmental trigger</rdfs:label>
  <stepOrder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</stepOrder>
  <stepCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Trigger</stepCategory>
  <stepDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Enteroviral infection or dietary antigens precipitate islet autoimmunity in genetically susceptible hosts.</stepDescription>
  <sourcePMID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://pubmed.ncbi.nlm.nih.gov/28958587/</sourcePMID>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Path_3_Tolerance">
  <rdf:type rdf:resource="#PathwayStep"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Loss of immune tolerance</rdfs:label>
  <stepOrder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</stepOrder>
  <stepCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Immune</stepCategory>
  <stepDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Impaired central/peripheral tolerance and defective Treg function permit autoreactive clones.</stepDescription>
  <sourcePMID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://pubmed.ncbi.nlm.nih.gov/25614315/</sourcePMID>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Path_4_Presentation">
  <rdf:type rdf:resource="#PathwayStep"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Antigen presentation</rdfs:label>
  <stepOrder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</stepOrder>
  <stepCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Immune</stepCategory>
  <stepDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dendritic cells and macrophages present beta-cell antigens in pancreatic lymph nodes.</stepDescription>
  <sourcePMID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://pubmed.ncbi.nlm.nih.gov/25614315/</sourcePMID>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Path_5_Autoantibodies">
  <rdf:type rdf:resource="#PathwayStep"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoantibody production</rdfs:label>
  <stepOrder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</stepOrder>
  <stepCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Antibody</stepCategory>
  <stepDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">B-cells produce GADA, IA-2A, IAA and ZnT8A, the serological hallmark of islet autoimmunity.</stepDescription>
  <sourcePMID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://pubmed.ncbi.nlm.nih.gov/25614315/</sourcePMID>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Path_6_Insulitis">
  <rdf:type rdf:resource="#PathwayStep"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">T-cell insulitis</rdfs:label>
  <stepOrder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">6</stepOrder>
  <stepCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Immune</stepCategory>
  <stepDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CD8+ cytotoxic and CD4+ Th1 cells infiltrate the islets (insulitis).</stepDescription>
  <sourcePMID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://pubmed.ncbi.nlm.nih.gov/25614315/</sourcePMID>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Path_7_BetaDeath">
  <rdf:type rdf:resource="#PathwayStep"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Beta-cell destruction</rdfs:label>
  <stepOrder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">7</stepOrder>
  <stepCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#string">TissueDamage</stepCategory>
  <stepDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Perforin/granzyme, Fas-FasL and cytokine (IL-1B, IFN-g, TNF) toxicity destroy beta cells.</stepDescription>
  <sourcePMID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://pubmed.ncbi.nlm.nih.gov/30269450/</sourcePMID>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Path_8_Insulin">
  <rdf:type rdf:resource="#PathwayStep"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Insulin deficiency &amp; hyperglycemia</rdfs:label>
  <stepOrder rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">8</stepOrder>
  <stepCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Outcome</stepCategory>
  <stepDescription rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Loss of &gt;80-90% beta-cell mass yields absolute insulin deficiency and clinical hyperglycemia.</stepDescription>
  <sourcePMID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://pubmed.ncbi.nlm.nih.gov/30609683/</sourcePMID>
</owl:NamedIndividual>

