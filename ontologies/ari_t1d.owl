  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lupus vasculitis</rdfs:label>
  <ARI_Obsolete rdf:datatype="http://www.w3.org/2001/XMLSchema#string">false</ARI_Obsolete>
  <ARI_ID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ARI:0001126</ARI_ID>
  <ARI_SNOMED rdf:datatype="http://www.w3.org/2001/XMLSchema#string">239944008</ARI_SNOMED>
  <ARI_OMOP rdf:datatype="http://www.w3.org/2001/XMLSchema#string">4344495</ARI_OMOP>
  <ARI_DXCODE rdf:datatype="http://www.w3.org/2001/XMLSchema#string">239944008</ARI_DXCODE>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lupus vasculitis is an autoimmune complication of lupus erythematosus that occurs when proteins of the immune system enter the walls of the blood vessels, leading to inflammation.  Patients often experience ulcers, red marks, or bumps on the skin.  The spectrum of involvement ranges from relatively mild disease (affecting only small vessels and skin), to life threatening multi-organ disease. Treatments are available to control symptoms.  Early medical attention is necessary in severe cases to prevent lasting damage to the organs.</rdfs:comment>
  <ARI_DefSource rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ramos-Casals 2006; https://pubmed.ncbi.nlm.nih.gov/16609348/</ARI_DefSource>
  <ARI_Pubmed rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://pubmed.ncbi.nlm.nih.gov/16609348/</ARI_Pubmed>
  <evidenceQuality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Antibody</evidenceQuality>
  <diseaseCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune</diseaseCategory>
  <ARI_Version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2</ARI_Version>
  <ageRange rdf:datatype="http://www.w3.org/2001/XMLSchema#string">17-73 years</ageRange>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lupus Research Alliance | https://www.lupusresearch.org/stay-informed/community/</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lupus and Allied Diseases Association | https://www.ladainc.org/</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lupus Foundation of America | https://www.lupus.org/</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">National Lupus Patient Registry | https://www.lupus.org/national-lupus-patient-registry</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Healthline | https://www.healthline.com/health/lupus/vasculitis-and-lupus</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Cleveland Clinic | https://my.clevelandclinic.org/health?q=Lupus%20vasculitis</ARI_RefLink>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lupus Vasculitis, Systemic - Affects internal organs.</ARI_ClinicalSubtype>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Lupus Vasculitis, Cutaneous - Skin involvement.</ARI_ClinicalSubtype>
  <ARI_Author rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Noopur Vijaya Goyal</ARI_Author>
  <ARI_AuthorDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2024-09</ARI_AuthorDate>
