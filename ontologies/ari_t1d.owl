  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Creaky Joints | https://creakyjoints.org/</ARI_RefLink>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Reactive Arthritis, Post-Infectious - Follows infection.</ARI_ClinicalSubtype>
