<owl:NamedIndividual rdf:about="https://diseases.autoimmuneregistry.org/disease/ARI_0001190">
  <rdf:type rdf:resource="#AutoimmuneDisease"/>
  <targetsTissue rdf:resource="#Tissue_Kidney"/>
  <hasSymptom rdf:resource="#Sym_0001190_1910"/>
  <hasSymptom rdf:resource="#Sym_0001190_1911"/>
