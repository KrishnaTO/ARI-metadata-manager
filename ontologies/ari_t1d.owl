  <ARI_PrevalenceDesc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Female 21836/100k; Male 20381/100k; F:M ratio 1.07139</ARI_PrevalenceDesc>
  <ageRange rdf:datatype="http://www.w3.org/2001/XMLSchema#string">0-10 years</ageRange>
