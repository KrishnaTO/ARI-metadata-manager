  <ARI_ICD10 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">D59.5</ARI_ICD10>
  <ARI_MESH rdf:datatype="http://www.w3.org/2001/XMLSchema#string">D006457</ARI_MESH>
