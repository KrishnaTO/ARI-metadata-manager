  <ARI_OMOP rdf:datatype="http://www.w3.org/2001/XMLSchema#string">4193776</ARI_OMOP>
  <ARI_DXCODE rdf:datatype="http://www.w3.org/2001/XMLSchema#string">79268002</ARI_DXCODE>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">POEMS is an acronym that stands for the disorder's features, which may include Polyneuropathy (disease affecting many nerves), Organomegaly (abnormal enlargement of an organ), Endocrinopathy (diseases affecting certain hormone-producing glands that help to regulate sexual function), Monoclonal gammopathy and Skin Changes. POEMS syndrome is a rare blood disorder where there is an uncontrolled growth of a single clone of plasma cells, which results in abnormal accumulation of immunoglobulins in the blood.</rdfs:comment>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Takatsuki syndrome</ARI_Synonym>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">PEP syndrome</ARI_Synonym>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Osteosclerotic myeloma</ARI_Synonym>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Polyneuropathy-organomegaly-endocrinopathy-M protein-skin lesions</ARI_Synonym>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Shimpo syndrome</ARI_Synonym>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Crow-Fukase syndrome</ARI_Synonym>
  <ARI_DefSource rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Wang 2019; https://www.ncbi.nlm.nih.gov/pmc/articles/PMC6598596/</ARI_DefSource>
  <evidenceQuality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Unconfirmed</evidenceQuality>
  <diseaseCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Unconfirmed</diseaseCategory>
  <ARI_Version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2</ARI_Version>
  <prevalencePer100k rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">76.0</prevalencePer100k>
  <ARI_PrevalenceDesc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Female 76/100k</ARI_PrevalenceDesc>
  <ageRange rdf:datatype="http://www.w3.org/2001/XMLSchema#string">21-84 years</ageRange>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Mayo Clinic | https://www.mayoclinic.org/diseases-conditions/poems-syndrome/symptoms-causes/syc-20352678</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Cleveland Clinic | https://my.clevelandclinic.org/health/diseases/17985-poems-syndrome</ARI_RefLink>
