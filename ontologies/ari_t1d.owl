  <ARI_ICD10 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">446.5</ARI_ICD10>
  <ARI_MESH rdf:datatype="http://www.w3.org/2001/XMLSchema#string">D013700</ARI_MESH>
