<owl:NamedIndividual rdf:about="#T1D_0002">
  <rdf:type rdf:resource="#AutoimmuneDisease"/>
  <hasParentDisease rdf:resource="https://diseases.autoimmuneregistry.org/disease/ARI_0001080"/>
  <hasParentCategory rdf:resource="#Category_Endocrine"/>
  <targetsTissue rdf:resource="#Tissue_BetaCell"/>
  <targetsTissue rdf:resource="#Tissue_Islet"/>
  <hasSymptom rdf:resource="#Sym_LADA_Thirst"/>
  <hasSymptom rdf:resource="#Sym_LADA_WeightLoss"/>
  <hasAntibody rdf:resource="#Ab_LADA_GAD65"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Latent autoimmune diabetes in adults (LADA)</rdfs:label>
  <ARI_ID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ARI:0002</ARI_ID>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">LADA is a slowly progressive form of autoimmune diabetes presenting in adulthood, characterized by GAD65 autoantibodies and gradual beta-cell failure that initially does not require insulin, bridging type 1 and type 2 diabetes phenotypes.</rdfs:comment>
  <ARI_Obsolete rdf:datatype="http://www.w3.org/2001/XMLSchema#string">false</ARI_Obsolete>
  <ARI_Version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1.0</ARI_Version>
  <diseaseCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune</diseaseCategory>
  <evidenceQuality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Moderate</evidenceQuality>
  <ageRange rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Adult-onset, typically &gt;30 years</ageRange>
  <prevalencePer100k rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">8.0</prevalencePer100k>
  <ARI_PrevalenceDesc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">~5-10% of adult-onset diabetes; ~8/100k.</ARI_PrevalenceDesc>
  <ARI_DefSource rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Diabetes Care LADA consensus; PMID: 32086290</ARI_DefSource>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">LADA</ARI_Synonym>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Type 1.5 diabetes</ARI_Synonym>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Slowly progressive IDDM</ARI_Synonym>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Latent autoimmune diabetes</ARI_Synonym>
  <ARI_DOID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">9744</ARI_DOID>
  <ARI_UMLS rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C2987933</ARI_UMLS>
  <ARI_MONDO rdf:datatype="http://www.w3.org/2001/XMLSchema#string">MONDO:0011027</ARI_MONDO>
  <ARI_ICD10 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">E10</ARI_ICD10>
  <ARI_ChangeLog rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2026-06-12 | System | Initial subtype entry</ARI_ChangeLog>
</owl:NamedIndividual>

