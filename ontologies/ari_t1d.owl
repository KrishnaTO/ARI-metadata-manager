  <rdf:type rdf:resource="#AutoimmuneDisease"/>
  <targetsTissue rdf:resource="#Tissue_VascularSystem"/>
  <hasSymptom rdf:resource="#Sym_0001051_387"/>
  <hasSymptom rdf:resource="#Sym_0001051_389"/>
  <hasSymptom rdf:resource="#Sym_0001051_390"/>
