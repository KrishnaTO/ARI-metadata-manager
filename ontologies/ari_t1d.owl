  <hasSymptom rdf:resource="#Sym_0001021_197"/>
  <hasSymptom rdf:resource="#Sym_0001021_198"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Aplastic anemia</rdfs:label>
  <ARI_Obsolete rdf:datatype="http://www.w3.org/2001/XMLSchema#string">false</ARI_Obsolete>
  <ARI_ID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ARI:0001021</ARI_ID>
  <ARI_SNOMED rdf:datatype="http://www.w3.org/2001/XMLSchema#string">306058006</ARI_SNOMED>
  <ARI_DOID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">12449</ARI_DOID>
  <ARI_UMLS rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C0002874</ARI_UMLS>
  <ARI_ICD10 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">284.9</ARI_ICD10>
  <ARI_ICD10 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">D61.9</ARI_ICD10>
  <ARI_MESH rdf:datatype="http://www.w3.org/2001/XMLSchema#string">D000741</ARI_MESH>
  <ARI_NCI rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C2870</ARI_NCI>
  <ARI_OMOP rdf:datatype="http://www.w3.org/2001/XMLSchema#string">137829</ARI_OMOP>
  <ARI_DXCODE rdf:datatype="http://www.w3.org/2001/XMLSchema#string">306058006</ARI_DXCODE>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Aplastic anemia is a rare and serious blood disorder that occurs when the body's bone marrow cannot make enough new red blood cells, impacting the body's ability to function normally. Aplastic anemia can progress at varying speeds and range from mild to severe. Currently, there's no known method to prevent it. This condition is caused by damage to stem cells inside the bone marrow, which is the sponge-like tissue within the bones. The immune system attacks and destroys and, as a result, the bone marrow makes fewer red blood cells, white blood cells, and platelets. This bone marrow damage is caused by the immune system attacking and destroying the stem cells within the bone marrow. Other causes of aplastic anemia include some medicine and exposure to environmental toxins or chemicals.</rdfs:comment>
  <ARI_DefSource rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Vaht 2017; https://www.ncbi.nlm.nih.gov/pmc/articles/PMC5622852/</ARI_DefSource>
  <evidenceQuality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">TCELL</evidenceQuality>
  <diseaseCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune</diseaseCategory>
  <ARI_Version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2</ARI_Version>
  <prevalencePer100k rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">128032.0</prevalencePer100k>
  <ARI_PrevalenceDesc rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Female 67196/100k; Male 60836/100k; F:M ratio 1.10454</ARI_PrevalenceDesc>
  <ageRange rdf:datatype="http://www.w3.org/2001/XMLSchema#string">15-25 years</ageRange>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Mayo Clinic | https://www.mayoclinic.org/diseases-conditions/aplastic-anemia/symptoms-causes/syc-20355015</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Cleveland Clinic | https://my.clevelandclinic.org/health/diseases/16747-aplastic-anemia</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Aplastic Anemia and MDS International Foundation | https://www.aamds.org/</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The Aplastic Anemia Trust Bloggers | https://www.theaat.org.uk/meet-our-bloggers</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The Aplastic Anemia Trust | https://www.theaat.org.uk/</ARI_RefLink>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Healthline | https://www.healthline.com/health/idiopathic-aplastic-anemia</ARI_RefLink>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Aplastic Anemia, Acquired - Caused by autoimmune attack, infections, or medications.</ARI_ClinicalSubtype>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Aplastic Anemia, Congenital (Fanconi Anemia) - Genetic disorder leading to bone marrow failure.</ARI_ClinicalSubtype>
  <ARI_Author rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fabliha Hussain | https://www.linkedin.com/in/fabliha-hussain/details/volunteering-experiences/</ARI_Author>
