  <ARI_DOID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">3429</ARI_DOID>
  <ARI_UMLS rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C0238190</ARI_UMLS>
  <ARI_ICD10 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">G72.41</ARI_ICD10>
  <ARI_ICD10 rdf:datatype="http://www.w3.org/2001/XMLSchema#string">359.71</ARI_ICD10>
  <ARI_MESH rdf:datatype="http://www.w3.org/2001/XMLSchema#string">D018979</ARI_MESH>
  <ARI_NCI rdf:datatype="http://www.w3.org/2001/XMLSchema#string">C84786</ARI_NCI>
  <ARI_OMOP rdf:datatype="http://www.w3.org/2001/XMLSchema#string">4216406</ARI_OMOP>
  <ARI_DXCODE rdf:datatype="http://www.w3.org/2001/XMLSchema#string">72315009</ARI_DXCODE>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Inclusion Body Myositis (IBM) is a chronic inflammatory muscle disease that causes painless weakening of the muscle. It is a chronic, slowly progressive condition that can lead to disability over the years. Studies show that IBM is more common in men than in women. Most people need assistance with basic daily activities within 15 years, and some people will need to use a wheelchair. The illness can be difficult to diagnose and is often first mistaken as polymyositis. It is not directly genetic, but predispositions may be present. Lifespan is thought to be normal, but severe complications include aspiration pneumonia that can lead to loss of life. There is currently no cure and standard course of treatment for IBM. Management options include physical therapy, exercise, speech therapy, and fall prevention.</rdfs:comment>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">IBM</ARI_Synonym>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Sporadic Inclusion Body Myositis</ARI_Synonym>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">sIBM</ARI_Synonym>
  <ARI_DefSource rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Greenberg 2016; https://pubmed.ncbi.nlm.nih.gov/30837708/</ARI_DefSource>
  <ARI_Pubmed rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://pubmed.ncbi.nlm.nih.gov/30837708/</ARI_Pubmed>
