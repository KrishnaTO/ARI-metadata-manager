  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Chronic obliterative cholangitis</ARI_Synonym>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fibrosing cholangitis</ARI_Synonym>
  <ARI_Synonym rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Stenosing cholangitis</ARI_Synonym>
