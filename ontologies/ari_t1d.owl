<owl:NamedIndividual rdf:about="https://diseases.autoimmuneregistry.org/disease/ARI_0001175">
  <rdf:type rdf:resource="#AutoimmuneDisease"/>
  <targetsTissue rdf:resource="#Tissue_NervousSystem"/>
  <hasSymptom rdf:resource="#Sym_0001175_1692"/>
  <hasSymptom rdf:resource="#Sym_0001175_1693"/>
  <hasSymptom rdf:resource="#Sym_0001175_1694"/>
  <hasSymptom rdf:resource="#Sym_0001175_1695"/>
  <hasSymptom rdf:resource="#Sym_0001175_1696"/>
  <hasSymptom rdf:resource="#Sym_0001175_1697"/>
  <hasSymptom rdf:resource="#Sym_0001175_1698"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rasmussen syndrome</rdfs:label>
  <ARI_Obsolete rdf:datatype="http://www.w3.org/2001/XMLSchema#string">false</ARI_Obsolete>
  <ARI_ID rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ARI:0001175</ARI_ID>
  <ARI_SNOMED rdf:datatype="http://www.w3.org/2001/XMLSchema#string">230191005</ARI_SNOMED>
  <ARI_SNOMED rdf:datatype="http://www.w3.org/2001/XMLSchema#string">435341000124104</ARI_SNOMED>
  <ARI_OMOP rdf:datatype="http://www.w3.org/2001/XMLSchema#string">4041672, 763040</ARI_OMOP>
  <ARI_DXCODE rdf:datatype="http://www.w3.org/2001/XMLSchema#string">230191005, 435341000124104</ARI_DXCODE>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rasmussen syndrome, or Rasmussen’s Encephalitis (RE), is a rare, progressive disease that involves cognitive decline due to inflammation of one half of the brain. Those with Rasmussen syndrome experience frequent seizures and eventual permanent brain damage. This disease mostly affects children ages 2 and 10, but can also affect adolescents and adults. Treatments for this disease include antiseizure medication, immunotherapy, and in more severe cases, brain surgery. The cause of Rasmussen's syndrome is unknown, however, researchers believe that it may be an autoimmune condition that affects one half of the brain or may occur due to an unknown virus entering the brain.</rdfs:comment>
  <ARI_DefSource rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bien 2013; https://pubmed.ncbi.nlm.nih.gov/23216622/</ARI_DefSource>
  <ARI_Pubmed rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://pubmed.ncbi.nlm.nih.gov/23216622/</ARI_Pubmed>
  <evidenceQuality rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Antibody</evidenceQuality>
  <diseaseCategory rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune</diseaseCategory>
  <ARI_Version rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2</ARI_Version>
  <ageRange rdf:datatype="http://www.w3.org/2001/XMLSchema#string">1-14 years</ageRange>
  <ARI_RefLink rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Link to Cleveland Clinic | https://my.clevelandclinic.org/health/diseases/6092-rasmussens-encephalitis</ARI_RefLink>
  <ARI_ClinicalSubtype rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Rasmussen Syndrome, Unilateral - Affects one hemisphere.</ARI_ClinicalSubtype>
  <ARI_Author rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Autoimmune Registry</ARI_Author>
  <ARI_AuthorDate rdf:datatype="http://www.w3.org/2001/XMLSchema#string">2024-09</ARI_AuthorDate>
